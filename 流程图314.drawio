        <mxCell id="-aLZxFvVy9og68MM8om5-3" parent="1" style="whiteSpace=wrap;html=1;verticalAlign=top;labelBackgroundColor=default;" value="&lt;b&gt;静态分析&lt;/b&gt;&lt;br&gt;A. 构建全局CFG&lt;br&gt;B.&amp;nbsp;计算程序的环形&lt;span data-path-to-node=&quot;13&quot; data-index-in-node=&quot;27&quot; style=&quot;&quot;&gt;复杂度&lt;span style=&quot;font-family: &amp;quot;Google Sans Text&amp;quot;, sans-serif; background-color: rgb(236, 236, 236);&quot;&gt;V(G)&lt;/span&gt;&lt;br&gt;C.数据流分析&lt;/span&gt;" vertex="1">
