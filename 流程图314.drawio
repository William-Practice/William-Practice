        <mxCell id="u6Nuiy7-A3NAGxYC8Qxy-1" parent="1" style="shape=image;verticalLabelPosition=bottom;labelBackgroundColor=default;verticalAlign=top;aspect=fixed;imageAspect=0;editableCssRules=.*;image=data:image/svg+xml,;" value="全局基本路径集" vertex="1">
