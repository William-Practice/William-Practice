        <mxCell id="oP28ooD_uX5hGmMyz6U6-2" parent="1" style="whiteSpace=wrap;html=1;verticalAlign=top;labelBackgroundColor=default;" value="&lt;div&gt;&lt;b&gt;子路径片段提取&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;Input:C&lt;br&gt;Output:&lt;/b&gt;D.提取循环体内部的 &lt;span class=&quot;math-inline&quot; data-math=&quot;0, 1, n&quot; data-index-in-node=&quot;23&quot; style=&quot;font-family: &amp;quot;Google Sans Text&amp;quot;, sans-serif !important; line-height: 1.15 !important; margin-top: 0px !important;&quot;&gt;0至 n&lt;/span&gt;次迭代对应的&lt;b data-path-to-node=&quot;6,2,0&quot; data-index-in-node=&quot;37&quot; style=&quot;font-family: &amp;quot;Google Sans Text&amp;quot;, sans-serif !important; line-height: 1.15 !important; margin-top: 0px !important;&quot;&gt;局部路径片段&lt;/b&gt;&lt;b&gt;&lt;/b&gt;&lt;/div&gt;" vertex="1">
